# Copy this file to config/.env and fill in your values
DB_HOST=localhost
DB_PORT=3306
DB_NAME=repair_system
DB_USER=root
DB_PASS=

APP_NAME=TechFix Repair System
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com/repair-system/public

SESSION_TIMEOUT=1800
SESSION_NAME=repair_sys_sess
CSRF_TOKEN_LENGTH=32

UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,webp

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=noreply@example.com
MAIL_PASS=
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=TechFix System

LOG_QUERIES=false
LOG_ERRORS=true
LOG_PATH=../logs/app.log
